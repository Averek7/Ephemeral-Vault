# Solana
# Use devnet or localnet depending on where your program is deployed.
# Devnet: https://api.devnet.solana.com
# Localnet: http://127.0.0.1:8899
RPC_URL=https://api.devnet.solana.com

# Anchor program id (must match the deployed program for the chosen cluster)
# From programs/ephemeralvault/src/lib.rs + Anchor.toml:
PROGRAM_ID=3L2LMJHHvgaGnvQ2ic7a5yu6DffLfoAQFLwFSjFJ4QQt

# Postgres
# If using backend/docker-compose.yml:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ephemeral_vault

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

